<launch>
  <!--
    只从 config/nav_params.yaml 读取运行参数。
    现场调参请改 yaml，不再由 launch 里的 arg 覆盖。
  -->
  <arg name="config_file" default="$(find rtk_reverse_nav)/config/nav_params.yaml"/>
  <arg name="enable_gui" default="true"/>

  <node pkg="rtk_reverse_nav" type="inspvax_to_utm_pose.py" name="inspvax_to_utm_pose" output="screen">
    <rosparam command="load" file="$(arg config_file)" />
  </node>

  <node pkg="rtk_reverse_nav" type="reverse_track_nav_node.py" name="reverse_track_nav_node" output="screen">
    <rosparam command="load" file="$(arg config_file)" />
  </node>

  <node if="$(arg enable_gui)" pkg="rtk_reverse_nav" type="controller_panel.py" name="controller_panel" output="screen">
    <rosparam command="load" file="$(arg config_file)" />
  </node>
</launch>
